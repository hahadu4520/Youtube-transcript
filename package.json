{
  "name": "youtube-transcript-skill",
  "version": "1.0.0",
  "description": "Extract timestamped YouTube transcripts with Markdown/JSON output, proxy support, translation, and Feishu/Lark handoff",
  "type": "module",
  "main": "extract.mjs",
  "scripts": {
    "extract": "node extract.mjs",
    "test": "node extract.mjs https://example.com --debug"
  },
  "keywords": [
    "youtube-transcript",
    "youtube",
    "transcript",
    "captions",
    "defuddle",
    "markdown"
  ],
  "author": "OpenClaw Community",
  "license": "MIT",
  "dependencies": {
    "defuddle": "^0.13.0",
    "linkedom": "^0.18.0",
    "undici": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
